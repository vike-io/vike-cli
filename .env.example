# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.
#
# `npm run test:e2e` auto-loads this file (see vitest.e2e.config.js); the live
# e2e tests skip cleanly if VIKE_API_KEY is absent, so a keyless run stays green.

# Required for the live e2e suite + ad-hoc CLI calls against the real API.
# Get one at https://vike.io/account?tab=api-keys
VIKE_API_KEY=vk_your_key_here

# Optional: point the CLI at a non-prod MCP endpoint (default: https://vike.io/mcp)
# VIKE_MCP_URL=https://vike.io/mcp

# Optional: silence telemetry / update checks during local runs.
VIKE_NO_TELEMETRY=1
# VIKE_NO_UPDATE_CHECK=1
